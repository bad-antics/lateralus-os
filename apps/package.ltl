// ===========================================================================
// LateralusOS — Package Manager (ltlpkg)
// ===========================================================================
// Copyright (c) 2025-2026 bad-antics. All rights reserved.
//
// Package manager for Lateralus modules within the OS.
// Manages local module registry, dependencies, and build artifacts.
//
// Usage:  pkg list                — list installed packages
//         pkg install <name>      — install from registry
//         pkg remove <name>       — uninstall package
//         pkg info <name>         — package details
//         pkg build               — build current project
//         pkg init <name>         — create new package
//         pkg search <query>      — search registry
// ===========================================================================

// -- Package metadata ----------------------------------------------------

struct PackageVersion {
    major: int
    minor: int
    patch: int
}

fn version_str(v: PackageVersion) -> str {
    str(v.major) ++ "." ++ str(v.minor) ++ "." ++ str(v.patch)
}

fn parse_version(s: str) -> PackageVersion {
    let parts = s.split(".")
    PackageVersion {
        major: if parts.len() > 0 { parts[0].parse_int() } else { 0 },
        minor: if parts.len() > 1 { parts[1].parse_int() } else { 0 },
        patch: if parts.len() > 2 { parts[2].parse_int() } else { 0 },
    }
}

fn version_gte(a: PackageVersion, b: PackageVersion) -> bool {
    if a.major > b.major { return true }
    if a.major < b.major { return false }
    if a.minor > b.minor { return true }
    if a.minor < b.minor { return false }
    a.patch >= b.patch
}

struct Package {
    name:         str
    version:      PackageVersion
    description:  str
    author:       str
    license:      str
    deps:         [str]
    files:        [str]
    installed:    bool
    size_bytes:   int
    category:     str
}

fn new_package(name: str, ver: str, desc: str) -> Package {
    Package {
        name:        name,
        version:     parse_version(ver),
        description: desc,
        author:      "lateralus-community",
        license:     "MIT",
        deps:        [],
        files:       [],
        installed:   false,
        size_bytes:  0,
        category:    "library",
    }
}

// -- Registry ------------------------------------------------------------

struct Registry {
    packages: [Package]
    base_path: str
}

fn builtin_registry() -> Registry {
    Registry {
        base_path: "/usr/lib/lateralus",
        packages: [
            // Core libraries
            new_package("core",        "1.0.0", "Core types and functions"),
            new_package("math",        "1.0.0", "Mathematics library (trig, linalg, stats)"),
            new_package("strings",     "1.0.0", "String manipulation utilities"),
            new_package("collections", "1.0.0", "Data structures (stack, queue, btree)"),
            new_package("io",          "1.0.0", "I/O abstractions"),
            new_package("json",        "1.0.0", "JSON parser and serializer"),
            new_package("csv",         "1.0.0", "CSV reader/writer"),
            new_package("regex",       "1.0.0", "Regular expression engine"),

            // Crypto & security
            new_package("crypto",      "1.0.0", "Cryptographic primitives (AES, SHA, HMAC)"),
            new_package("uuid",        "1.0.0", "UUID v4 generator"),
            new_package("base64",      "1.0.0", "Base64 encoding/decoding"),

            // System
            new_package("os",          "1.0.0", "OS interface (process, signals, env)"),
            new_package("async",       "1.0.0", "Async/await runtime"),
            new_package("sync",        "1.0.0", "Synchronization primitives (mutex, rwlock)"),
            new_package("channel",     "1.0.0", "Channel-based message passing"),
            new_package("time",        "1.0.0", "Time and duration utilities"),
            new_package("datetime",    "1.0.0", "Date/time formatting and parsing"),

            // Networking
            new_package("network",     "1.0.0", "TCP/UDP networking"),
            new_package("http",        "1.0.0", "HTTP client/server"),

            // Science & Data
            new_package("linalg",      "1.0.0", "Linear algebra (vectors, matrices)"),
            new_package("stats",       "1.0.0", "Statistical functions"),
            new_package("science",     "1.0.0", "Scientific computing helpers"),
            new_package("signals",     "1.0.0", "Signal processing (FFT, filters)"),

            // Testing
            new_package("testing",     "1.0.0", "Test framework (assert, bench)"),
            new_package("logging",     "1.0.0", "Structured logging"),

            // Apps
            new_package("ltlchat",     "1.0.0", "Chat client for LateralusOS"),
