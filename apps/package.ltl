// -- Package operations --------------------------------------------------

fn pkg_list(registry: Registry) -> [str] {
    let mut lines: [str] = []
    lines = lines ++ ["Installed packages:"]
    lines = lines ++ ["==========================================="]
    let mut count = 0
    for pkg in registry.packages {
        if pkg.installed {
            let line = "  " ++ pkg.name ++ " v" ++ version_str(pkg.version)
                ++ " — " ++ pkg.description
            lines = lines ++ [line]
            count = count + 1
        }
    }
    if count == 0 {
        lines = lines ++ ["  (no packages installed)"]
    }
    lines = lines ++ [""]
    lines = lines ++ [str(count) ++ " package(s) installed"]
    lines
}

fn pkg_search(registry: Registry, query: str) -> [str] {
    let mut lines: [str] = []
    lines = lines ++ ["Search results for '" ++ query ++ "':"]
    lines = lines ++ ["==========================================="]
    let lower_q = query.to_lower()
    let mut count = 0
    for pkg in registry.packages {
        if pkg.name.to_lower().contains(lower_q) || pkg.description.to_lower().contains(lower_q) {
            let status = if pkg.installed { "[installed]" } else { "[available]" }
            let line = "  " ++ pkg.name ++ " v" ++ version_str(pkg.version)
                ++ " " ++ status ++ " — " ++ pkg.description
            lines = lines ++ [line]
            count = count + 1
        }
    }
    if count == 0 {
        lines = lines ++ ["  No packages found matching '" ++ query ++ "'"]
    }
    lines
}

fn pkg_info(registry: Registry, name: str) -> [str] {
    for pkg in registry.packages {
        if pkg.name == name {
            return [
                "Package: " ++ pkg.name,
                "Version: " ++ version_str(pkg.version),
                "Description: " ++ pkg.description,
                "Author: " ++ pkg.author,
                "License: " ++ pkg.license,
                "Category: " ++ pkg.category,
                "Status: " ++ if pkg.installed { "Installed" } else { "Available" },
                "Dependencies: " ++ if pkg.deps.len() > 0 { pkg.deps.join(", ") } else { "none" },
                "Size: " ++ str(pkg.size_bytes) ++ " bytes",
            ]
        }
    }
    ["Package '" ++ name ++ "' not found in registry"]
}

fn pkg_install(registry: Registry, name: str) -> (Registry, [str]) {
    let mut new_pkgs = registry.packages
    for i in 0..new_pkgs.len() {
        if new_pkgs[i].name == name {
            if new_pkgs[i].installed {
                return (registry, ["Package '" ++ name ++ "' is already installed"])
            }
            new_pkgs[i] = Package { ..new_pkgs[i], installed: true }
            let msg = [
                "Installing " ++ name ++ " v" ++ version_str(new_pkgs[i].version) ++ "...",
                "  Resolving dependencies...",
                "  Downloading package...",
                "  Verifying checksum...",
                "  Installing to " ++ registry.base_path ++ "/" ++ name ++ "/",
                "  ✓ " ++ name ++ " installed successfully",
            ]
            return (Registry { ..registry, packages: new_pkgs }, msg)
        }
    }
    (registry, ["Error: package '" ++ name ++ "' not found in registry"])
}

fn pkg_remove(registry: Registry, name: str) -> (Registry, [str]) {
    let mut new_pkgs = registry.packages
    for i in 0..new_pkgs.len() {
        if new_pkgs[i].name == name {
            if !new_pkgs[i].installed {
                return (registry, ["Package '" ++ name ++ "' is not installed"])
            }
            new_pkgs[i] = Package { ..new_pkgs[i], installed: false }
            return (
                Registry { ..registry, packages: new_pkgs },
                ["Removing " ++ name ++ "...", "  ✓ " ++ name ++ " removed successfully"],
            )
        }
    }
    (registry, ["Error: package '" ++ name ++ "' not found"])
}

// -- Build system --------------------------------------------------------

struct BuildConfig {
    name:        str
    version:     str
    entry:       str
    target:      str       // "c", "bytecode", "native"
    freestanding: bool
    optimize:    bool
    sources:     [str]
    output:      str
}

fn default_build_config() -> BuildConfig {
    BuildConfig {
        name:        "myproject",
        version:     "0.1.0",
        entry:       "src/main.ltl",
        target:      "c",
        freestanding: false,
        optimize:    true,
        sources:     ["src/"],
        output:      "build/",
    }
}

fn build_project(config: BuildConfig) -> [str] {
    let mut output: [str] = []
    output = output ++ ["Building " ++ config.name ++ " v" ++ config.version ++ "..."]
    output = output ++ ["  Target: " ++ config.target]
    output = output ++ ["  Freestanding: " ++ str(config.freestanding)]
    output = output ++ ["  Entry: " ++ config.entry]
    output = output ++ ["  Optimize: " ++ str(config.optimize)]
    output = output ++ [""]

    // Phase 1: Discover sources
    output = output ++ ["[1/4] Discovering source files..."]
    output = output ++ ["  Found " ++ str(config.sources.len()) ++ " source directories"]

    // Phase 2: Compile
    output = output ++ ["[2/4] Compiling..."]
    output = output ++ ["  lateralus c " ++ config.entry ++ " --target=" ++ config.target]

    // Phase 3: Link
    output = output ++ ["[3/4] Linking..."]
    output = output ++ ["  Output: " ++ config.output ++ config.name]

    // Phase 4: Done
    output = output ++ ["[4/4] Build complete"]
    output = output ++ ["  ✓ " ++ config.name ++ " built successfully"]
    output
}

fn init_project(name: str) -> [str] {
    [
        "Creating new project '" ++ name ++ "'...",
        "  mkdir " ++ name ++ "/",
        "  mkdir " ++ name ++ "/src/",
        "  create " ++ name ++ "/src/main.ltl",
        "  create " ++ name ++ "/lateralus.toml",
        "  create " ++ name ++ "/README.md",
        "",
        "  ✓ Project '" ++ name ++ "' initialized",
        "",
        "  To build:  cd " ++ name ++ " && pkg build",
        "  To run:    ltlc run src/main.ltl",
    ]
}
