import hal::serial

struct ColorScheme {
    // Window chrome
    bg:             int,
    surface0:       int,
    surface1:       int,
    surface2:       int,
    border:         int,
    title_active:   int,
    title_inactive: int,
    btn_close:      int,
    btn_max:        int,
    btn_min:        int,
    // Text
    text:           int,
    text_muted:     int,
    text_accent:    int,
    // UI elements
    accent:         int,
    accent_hover:   int,
    accent_pressed: int,
    selection:      int,
    cursor:         int,
    // Status colors
    red:     int,
    green:   int,
    yellow:  int,
    blue:    int,
    magenta: int,
    cyan:    int,
    white:   int,
    // Taskbar
    taskbar_bg:     int,
    taskbar_btn:    int,
    taskbar_text:   int,
}

