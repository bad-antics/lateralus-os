let mut active_theme: ColorScheme = THEME_CATPPUCCIN_MOCHA
let mut theme_name:   str = "catppuccin-mocha"

pub fn get_active() -> ColorScheme { return active_theme }
pub fn get_name()   -> str         { return theme_name   }

pub fn set_theme(name: str) {
    match name {
        "catppuccin-mocha" => { active_theme = THEME_CATPPUCCIN_MOCHA; theme_name = name }
        "catppuccin-latte" => { active_theme = THEME_CATPPUCCIN_LATTE; theme_name = name }
        "nord"             => { active_theme = THEME_NORD;             theme_name = name }
        _                  => { serial::log("[theme] Unknown theme: {name}") }
    }
    serial::log("[theme] Active theme: {theme_name}")
}

pub fn list_themes() -> [str] {
    return ["catppuccin-mocha", "catppuccin-latte", "nord"]
}

pub fn rgb(r: int, g: int, b: int) -> int {
    return 0xFF000000 | (r << 16) | (g << 8) | b
}

pub fn rgba(r: int, g: int, b: int, a: int) -> int {
    return (a << 24) | (r << 16) | (g << 8) | b
}

pub fn blend_colors(c1: int, c2: int, t: float) -> int {
    let r1 = (c1 >> 16) & 0xFF; let r2 = (c2 >> 16) & 0xFF
    let g1 = (c1 >> 8)  & 0xFF; let g2 = (c2 >> 8)  & 0xFF
    let b1 = c1 & 0xFF;          let b2 = c2 & 0xFF
    let r = (r1 as float * (1.0 - t) + r2 as float * t) as int
    let g = (g1 as float * (1.0 - t) + g2 as float * t) as int
    let b = (b1 as float * (1.0 - t) + b2 as float * t) as int
    return rgb(r, g, b)
}

pub fn darken(color: int, amount: float) -> int { return blend_colors(color, 0xFF000000, amount) }
pub fn lighten(color: int, amount: float) -> int { return blend_colors(color, 0xFFFFFFFF, amount) }
