import hal::serial
import hal::cpu
import kernel::ipc
import kernel::scheduler

const KEY_SIZE_256 = 32
const KEY_SIZE_512 = 64
const BLOCK_SIZE   = 16    // AES block size
const GCM_TAG_SIZE = 16

// -- State ---------------------------------------------------------------

struct CryptoState {
    hw_rng_available: bool,
    keys_generated:   int,
    operations:       int,
    initialized:      bool,
}

let mut state = CryptoState {
    hw_rng_available: false,
    keys_generated:   0,
    operations:       0,
    initialized:      false,
}

// -- Init ----------------------------------------------------------------

pub fn start() {
    serial::log("[crypto] Starting cryptographic services")

    // Check for hardware RNG (RDRAND)
    state.hw_rng_available = cpu::cpu_features.has_rdrand
    if state.hw_rng_available {
        serial::log("[crypto] Hardware RNG (RDRAND) available")
    } else {
        serial::log("[crypto] WARNING: No hardware RNG — using LFSR fallback")
    }

    // Check for AES-NI
    if cpu::cpu_features.has_aes {
        serial::log("[crypto] AES-NI hardware acceleration available")
    }

    state.initialized = true

    // Create service IPC channel
    let ch = match ipc::channel_create("crypto_svc", 64) {
        Result::Ok(id) => id,
        Result::Err(e) => {
            serial::log("[crypto] Cannot create channel: {e}")
            return
        },
    }

    serial::log("[crypto] Crypto service ready")

    // Service loop — wait for encryption/decryption requests
    while state.initialized {
        match ipc::channel_recv(ch) {
            Result::Ok(request) => {
                // Process crypto request
                state.operations = state.operations + 1
            },
            Result::Err(_) => {},
        }
    }
}

// -- Key Generation ------------------------------------------------------

pub fn generate_key(size: int) -> [byte; 32] {
    let key: [byte; 32] = [0; 32]

    if state.hw_rng_available {
        // Use RDRAND for true randomness
        let i = 0
        while i < size && i < 32 {
            key[i] = rdrand_byte()
            i = i + 1
        }
    } else {
        // LFSR-based fallback (seeded from timer)
        let seed = scheduler::get_ticks() ^ 0xDEADBEEF5A5A5A5A
        let i = 0
        while i < size && i < 32 {
            seed = lfsr_next(seed)
            key[i] = (seed & 0xFF) as byte
            i = i + 1
        }
    }

    state.keys_generated = state.keys_generated + 1
    return key
}

fn rdrand_byte() -> byte {
    let val = 0
    foreign "asm" (val: val) { "rdrand eax" }
    return (val & 0xFF) as byte
}

fn lfsr_next(state: int) -> int {
    // 64-bit LFSR with taps at positions 64, 63, 61, 60
    let bit = ((state >> 63) ^ (state >> 62) ^ (state >> 60) ^ (state >> 59)) & 1
    return (state << 1) | bit
}

// -- AES-256 (software implementation) -----------------------------------

// AES S-Box
let SBOX: [byte; 256] = [
    0x63, 0x7C, 0x77, 0x7B, 0xF2, 0x6B, 0x6F, 0xC5,
    0x30, 0x01, 0x67, 0x2B, 0xFE, 0xD7, 0xAB, 0x76,
    // ... (full 256-byte S-box would be here)
    // Abbreviated for readability — full implementation in C backend
]

pub fn encrypt(data: [byte], key: [byte; 32]) -> [byte] {
    state.operations = state.operations + 1

    // AES-256-GCM encryption
    // 1. Generate 12-byte IV from RNG
    let iv: [byte; 12] = [0; 12]
    let i = 0
    while i < 12 {
        iv[i] = rdrand_byte()
        i = i + 1
    }

    // 2. AES key expansion (14 rounds for AES-256)
    let round_keys = key_expansion(key)

    // 3. CTR mode encryption
    let encrypted = ctr_encrypt(data, round_keys, iv)

    // 4. GCM authentication tag
    let tag = compute_ghash(encrypted, key, iv)

    // 5. Prepend IV and append tag: [IV:12][ciphertext:N][tag:16]
    let output = iv + encrypted + tag
    return output
}

pub fn decrypt(data: [byte], key: [byte; 32]) -> Result<[byte], str> {
    state.operations = state.operations + 1

    if data.len() < 12 + GCM_TAG_SIZE {
        return Result::Err("Ciphertext too short")
    }

    // Extract IV, ciphertext, and tag
    let iv = data[0..12]
    let ciphertext = data[12..data.len() - GCM_TAG_SIZE]
    let tag = data[data.len() - GCM_TAG_SIZE..]

    // Verify authentication tag
    let round_keys = key_expansion(key)
    let expected_tag = compute_ghash(ciphertext, key, iv)

    if !constant_time_eq(tag, expected_tag) {
        return Result::Err("Authentication failed — data tampered")
    }

    // Decrypt (CTR mode — same as encrypt)
    let plaintext = ctr_encrypt(ciphertext, round_keys, iv)
    return Result::Ok(plaintext)
}

// -- SHA-256 -------------------------------------------------------------

pub fn sha256(data: [byte]) -> [byte; 32] {
    state.operations = state.operations + 1

    // Initial hash values (first 32 bits of fractional parts of sqrt of primes)
    let mut h0 = 0x6A09E667
    let mut h1 = 0xBB67AE85
    let mut h2 = 0x3C6EF372
    let mut h3 = 0xA54FF53A
    let mut h4 = 0x510E527F
    let mut h5 = 0x9B05688C
    let mut h6 = 0x1F83D9AB
    let mut h7 = 0x5BE0CD19

    // Pad message to 512-bit blocks
    let padded = sha256_pad(data)

    // Process each 512-bit block
    let block = 0
    while block < padded.len() / 64 {
        // Message schedule (64 words)
        let w: [int; 64] = [0; 64]
        let i = 0
        while i < 16 {
            let offset = block * 64 + i * 4
            w[i] = (padded[offset] << 24) | (padded[offset+1] << 16) |
                   (padded[offset+2] << 8) | padded[offset+3]
            i = i + 1
        }
        while i < 64 {
            let s0 = rotr(w[i-15], 7) ^ rotr(w[i-15], 18) ^ (w[i-15] >> 3)
            let s1 = rotr(w[i-2], 17) ^ rotr(w[i-2], 19) ^ (w[i-2] >> 10)
            w[i] = w[i-16] + s0 + w[i-7] + s1
            i = i + 1
        }

        // Compression (64 rounds)
        // ... (full SHA-256 compression rounds)

        block = block + 1
    }

    // Produce final hash
    let hash: [byte; 32] = [0; 32]
    // ... pack h0-h7 into 32 bytes
    return hash
}

fn sha256_pad(data: [byte]) -> [byte] {
    let len = data.len()
    let bit_len = len * 8

    // Append 0x80 byte
    let padded = data + [0x80]

    // Pad to 56 mod 64 bytes
    while padded.len() % 64 != 56 {
        padded = padded + [0x00]
    }

    // Append 64-bit big-endian length
    let i = 56
    while i >= 0 {
        padded = padded + [(bit_len >> i) & 0xFF]
        i = i - 8
    }

    return padded
}

fn rotr(x: int, n: int) -> int {
    return ((x >> n) | (x << (32 - n))) & 0xFFFFFFFF
}

// -- HMAC ----------------------------------------------------------------

pub fn hmac_sha256(data: [byte], key: [byte]) -> [byte; 32] {
    let block_size = 64

    // Key preprocessing
    let k = if key.len() > block_size { sha256(key) } else { key }

    // Pad key to block size
    while k.len() < block_size {
        k = k + [0x00]
    }

    // Inner and outer pads
    let ipad: [byte; 64] = [0; 64]
    let opad: [byte; 64] = [0; 64]
    let i = 0
    while i < block_size {
        ipad[i] = k[i] ^ 0x36
        opad[i] = k[i] ^ 0x5C
        i = i + 1
    }

    let inner = sha256(ipad + data)
    let outer = sha256(opad + inner)
    return outer
}

// -- Build Watermark -----------------------------------------------------
// Embeds a unique, verifiable watermark in test builds to trace leaks.

pub fn generate_watermark(build_id: str, tester_id: str) -> [byte; 64] {
    let data = "LATERALUS-WM|{build_id}|{tester_id}|{scheduler::get_ticks()}"
    let hash = sha256(data.as_bytes())
    let signature = hmac_sha256(hash, generate_key(32))

    let watermark: [byte; 64] = [0; 64]
    let i = 0
    while i < 32 {
        watermark[i] = hash[i]
        watermark[i + 32] = signature[i]
        i = i + 1
    }
    return watermark
}

pub fn verify_watermark(watermark: [byte; 64], build_id: str, tester_id: str) -> bool {
    let data = "LATERALUS-WM|{build_id}|{tester_id}"
    let expected_hash = sha256(data.as_bytes())
    return constant_time_eq(watermark[0..32], expected_hash)
}

// -- Helpers -------------------------------------------------------------

fn constant_time_eq(a: [byte], b: [byte]) -> bool {
    if a.len() != b.len() { return false }
    let diff = 0
    let i = 0
    while i < a.len() {
        diff = diff | (a[i] ^ b[i])
        i = i + 1
    }
    return diff == 0
}

fn key_expansion(key: [byte; 32]) -> [int; 60] {
