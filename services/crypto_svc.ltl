    let expanded: [int; 60] = [0; 60]
    // ... (full key expansion implementation)
    return expanded
}

fn ctr_encrypt(data: [byte], keys: [int; 60], iv: [byte; 12]) -> [byte] {
    // AES-CTR mode
    let output: [byte] = []
    let block_count = (data.len() + BLOCK_SIZE - 1) / BLOCK_SIZE
    let counter = 0

    while counter < block_count {
        // Build counter block: [IV:12][counter:4]
        let ctr_block: [byte; 16] = [0; 16]
        let i = 0
        while i < 12 { ctr_block[i] = iv[i]; i = i + 1 }
        ctr_block[12] = ((counter >> 24) & 0xFF) as byte
        ctr_block[13] = ((counter >> 16) & 0xFF) as byte
        ctr_block[14] = ((counter >> 8) & 0xFF) as byte
        ctr_block[15] = (counter & 0xFF) as byte

        // Encrypt counter block
        let keystream = aes_encrypt_block(ctr_block, keys)

        // XOR with plaintext
        let j = 0
        while j < BLOCK_SIZE && (counter * BLOCK_SIZE + j) < data.len() {
            output = output + [(data[counter * BLOCK_SIZE + j] ^ keystream[j])]
            j = j + 1
        }

        counter = counter + 1
    }

    return output
}

fn aes_encrypt_block(block: [byte; 16], keys: [int; 60]) -> [byte; 16] {
    // Single AES-256 block encryption (14 rounds)
    let state: [byte; 16] = block
