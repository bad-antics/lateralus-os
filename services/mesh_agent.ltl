//
// Enables deployment and management of custom agents across mesh-connected
// machines running LateralusOS. Features:
//   • Node discovery (multicast/mDNS)
//   • Secure peer-to-peer communication (TLS + Lateralus crypto)
//   • Remote agent deployment (push .ltl programs to peers)
//   • Task distribution and result collection
//   • Health monitoring across the mesh
// ===========================================================================

import hal::serial
import drivers::network
import kernel::ipc
import kernel::scheduler
import services::crypto_svc

const MESH_PORT         = 7331       // Lateralus mesh protocol port
const MAX_MESH_NODES    = 64
const HEARTBEAT_INTERVAL = 5000      // 5 second heartbeat
const NODE_TIMEOUT      = 15000      // 15 seconds before node considered dead

const MESH_MSG_DISCOVER  = 0x01
const MESH_MSG_HEARTBEAT = 0x02
const MESH_MSG_DEPLOY    = 0x03
const MESH_MSG_TASK      = 0x04
const MESH_MSG_RESULT    = 0x05
const MESH_MSG_STATUS    = 0x06
const MESH_MSG_SHUTDOWN  = 0xFF

// -- Mesh Node -----------------------------------------------------------

struct MeshNode {
    id:          str,        // unique node identifier
    address:     str,        // IP address
    port:        int,
    hostname:    str,
    edition:     str,        // OS edition (industrial, research, etc.)
    status:      str,        // "online", "offline", "busy"
    last_seen:   int,        // tick count of last heartbeat
    cpu_usage:   int,        // 0-100%
    mem_free:    int,        // KB free
    tasks_running: int,
    active:      bool,
}

// -- Mesh Agent State ----------------------------------------------------

struct MeshAgent {
    node_id:     str,
    nodes:       [MeshNode; MAX_MESH_NODES],
    node_count:  int,
    running:     bool,
    tasks_sent:  int,
    tasks_done:  int,
    bytes_tx:    int,
    bytes_rx:    int,
    auth_key:    [byte; 32],    // symmetric key for mesh auth
}

let mut agent = MeshAgent {
    node_id:     "",
    nodes:       [MeshNode{}; MAX_MESH_NODES],
    node_count:  0,
    running:     false,
    tasks_sent:  0,
    tasks_done:  0,
    bytes_tx:    0,
    bytes_rx:    0,
    auth_key:    [0; 32],
}

// -- Init ----------------------------------------------------------------

pub fn start() {
    serial::log("[mesh] Starting mesh agent")

    // Generate node ID from MAC address
    let mac = network::get_mac()
    agent.node_id = "ltl-{mac[0]:02X}{mac[1]:02X}{mac[2]:02X}{mac[3]:02X}{mac[4]:02X}{mac[5]:02X}"

    // Generate or load authentication key
    agent.auth_key = crypto_svc::generate_key(32)

    agent.running = true
    serial::log("[mesh] Node ID: {agent.node_id}")
    serial::log("[mesh] Listening on port {MESH_PORT}")

    // Create IPC channels for mesh communication
    let cmd_ch = match ipc::channel_create("mesh_cmd", 32) {
        Result::Ok(id) => id,
        Result::Err(e) => {
            serial::log("[mesh] Cannot create command channel: {e}")
            return
        },
    }

    // Main agent loop
    while agent.running {
        // Send heartbeat to all known nodes
        send_heartbeats()

        // Check for incoming messages
        process_incoming()

        // Prune dead nodes
        prune_dead_nodes()

        // Check command channel for local commands
        if ipc::channel_has_data(cmd_ch) {
            match ipc::channel_recv(cmd_ch) {
                Result::Ok(cmd) => handle_command(cmd),
                Result::Err(_) => {},
            }
        }

        // Sleep until next cycle
        scheduler::sleep_current(HEARTBEAT_INTERVAL)
    }
}

// -- Node Discovery ------------------------------------------------------

fn send_heartbeats() {
    let i = 0
    while i < agent.node_count {
        if agent.nodes[i].active {
            let msg = build_heartbeat_packet()
            // network::send_to(agent.nodes[i].address, MESH_PORT, msg)
            agent.bytes_tx = agent.bytes_tx + msg.len()
        }
        i = i + 1
    }
}

fn build_heartbeat_packet() -> [byte] {
    // Build mesh protocol heartbeat
    // Format: [MSG_TYPE:1][NODE_ID:6][CPU:1][MEM_FREE:4][TASKS:2][CHECKSUM:4]
    return [
        MESH_MSG_HEARTBEAT as byte,
        // ... node data ...
    ]
}

fn process_incoming() {
    // Poll network for incoming mesh packets
    // In a real implementation, this would read from a raw socket
}

fn prune_dead_nodes() {
    let current_tick = scheduler::get_ticks()
    let i = 0
    while i < agent.node_count {
        if agent.nodes[i].active {
            let elapsed = current_tick - agent.nodes[i].last_seen
            if elapsed > NODE_TIMEOUT {
                serial::log("[mesh] Node {agent.nodes[i].id} timed out")
                agent.nodes[i].active = false
                agent.nodes[i].status = "offline"
            }
        }
        i = i + 1
    }
}

// -- Agent Deployment ----------------------------------------------------

pub fn deploy_agent(target_node: str, agent_code: [byte]) -> Result<bool, str> {
    // Find target node
    let node = find_node(target_node)
    match node {
        Option::Some(n) => {
            if n.status != "online" {
                return Result::Err("Node {target_node} is {n.status}")
            }

            // Encrypt agent code before transmission
            let encrypted = crypto_svc::encrypt(agent_code, agent.auth_key)

            // Build deploy packet
            let packet = [MESH_MSG_DEPLOY as byte]  // + encrypted payload

            // Send to target
            // network::send_to(n.address, MESH_PORT, packet)

            agent.tasks_sent = agent.tasks_sent + 1
            serial::log("[mesh] Deployed agent to {target_node}")
            return Result::Ok(true)
        },
        Option::None => return Result::Err("Unknown node: {target_node}"),
    }
}

pub fn send_task(target_node: str, task_data: [byte]) -> Result<int, str> {
    let node = find_node(target_node)
    match node {
        Option::Some(n) => {
            let encrypted = crypto_svc::encrypt(task_data, agent.auth_key)
            // Send task packet
            agent.tasks_sent = agent.tasks_sent + 1
            return Result::Ok(agent.tasks_sent)
        },
        Option::None => return Result::Err("Unknown node: {target_node}"),
    }
}

// -- Helpers -------------------------------------------------------------

fn find_node(id: str) -> Option<MeshNode> {
    let i = 0
    while i < agent.node_count {
        if agent.nodes[i].id == id && agent.nodes[i].active {
            return Option::Some(agent.nodes[i])
        }
        i = i + 1
    }
    return Option::None
}

fn handle_command(cmd: int) {
    match cmd {
        0 => { agent.running = false },  // shutdown
        _ => {},
    }
}

pub fn connect(address: str) -> Result<bool, str> {
    if agent.node_count >= MAX_MESH_NODES {
        return Result::Err("Mesh node table full")
    }

    agent.nodes[agent.node_count] = MeshNode {
        id:            "",
        address:       address,
        port:          MESH_PORT,
        hostname:      "",
        edition:       "",
        status:        "connecting",
        last_seen:     scheduler::get_ticks(),
        cpu_usage:     0,
        mem_free:      0,
        tasks_running: 0,
        active:        true,
    }
    agent.node_count = agent.node_count + 1

    serial::log("[mesh] Connecting to {address}...")
    return Result::Ok(true)
}

pub fn get_node_count() -> int {
    return agent.node_count
}

pub fn get_stats() -> (int, int, int, int) {
    return (agent.node_count, agent.tasks_sent, agent.tasks_done, agent.bytes_tx)
}
